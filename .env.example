SPYDUS_BASE_URL=https://your-library.spydus.com
SPYDUS_USER=your_library_card_number
SPYDUS_PASSWORD=your_library_password

# Optional library profile selector (matches SPYDUS_<PROFILE>_* keys)
SPYDUS_LIBRARY=default

# Example profile: ACT
SPYDUS_ACT_BASE_URL=https://librariesact.spydus.com
SPYDUS_ACT_USER=your_act_card_number
SPYDUS_ACT_PASSWORD=your_act_password
